# Database — SQLite file. Local dev uses a file in the prisma dir; Docker uses /data volume.
DATABASE_URL="file:./dev.db"

# Admin panel login (single password, no username).
ADMIN_PASSWORD="change-this-password"

# Secret used to sign the admin session cookie. Use a long random string (32+ chars).
# Generate one with: openssl rand -base64 32
SESSION_SECRET="change-this-to-a-long-random-secret"

# Directory where uploaded images are stored (served at /uploads/<file>).
UPLOAD_DIR="public/uploads"

# Node environment.
NODE_ENV="production"
